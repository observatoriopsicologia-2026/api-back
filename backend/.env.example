# API
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:4200
JWT_SECRET=change-this-before-deploying

# Initial admin user. The API creates it on startup if it does not exist.
ADMIN_NAME=Administrador POT
ADMIN_EMAIL=admin@observatorio.local
ADMIN_PASSWORD=ChangeMe123!

# PostgreSQL connection string from Supabase, Neon, or another hosted Postgres.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.wfigtnmzzovppkvnkdua.supabase.co:5432/postgres

# File storage.
# Use "local" for local development. Use "supabase" for deployment.
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=uploads

# Supabase Storage, required when STORAGE_DRIVER=supabase.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PUBLICATION_BUCKET=publications

